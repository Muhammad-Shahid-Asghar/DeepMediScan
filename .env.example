# ============================================================
#  DeepMediScan — environment template
#  1. Copy this file and rename the copy to:  .env
#  2. Put your real key after the = sign
#  3. NEVER commit the real .env file (it is in .gitignore)
# ============================================================

# Groq API key — powers the AI chat assistant (/chat endpoint).
# Get a free key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# (Optional) Custom project folder — only set this if your models/dataset
# are NOT in the same folder as main.py. Otherwise leave it commented out.
# DERMAI_DIR=C:\path\to\your\project\folder
